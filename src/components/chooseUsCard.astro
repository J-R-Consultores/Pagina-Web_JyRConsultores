---
import { Icon } from "astro-icon/components";

interface Props {
    titulo: string;
    descripcion: string;
    icon: string;
}

const { titulo, descripcion, icon } = Astro.props;
---

<article class="flex items-start gap-5 group">
    <div
        class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 group-hover:scale-110 group-hover:shadow-blue-100 transition-all duration-300"
    >
        <Icon
            name={icon}
            class="w-6 h-6 text-slate-800 group-hover:text-blue-600 transition-colors"
        />
    </div>

    <div class="flex flex-col">
        <h3
            class="text-xl font-bold text-slate-900 mb-2 tracking-tight group-hover:text-blue-700 transition-colors"
        >
            {titulo}
        </h3>

        <p class="text-slate-600 text-sm leading-relaxed font-medium">
            {descripcion}
        </p>
    </div>
</article>
