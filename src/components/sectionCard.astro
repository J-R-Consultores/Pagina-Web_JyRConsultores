---
import { Icon } from "astro-icon/components";

interface CardItem {
    titulo: string;
    descripcion: string;
    icon: string;
}

interface Props {
    tituloSeccion: string;
    items: CardItem[];
    textoBoton?: string;
    enlaceBoton?: string;
    bgColor?: string;
}

const {
    tituloSeccion,
    items,
    textoBoton,
    enlaceBoton = "#",
    bgColor = "bg-[#fdfeff]", // Cambiado a un blanco casi puro para mayor limpieza
} = Astro.props;
---

<section class={`py-24 px-6 overflow-hidden ${bgColor}`}>
    <div class="max-w-7xl mx-auto text-center relative">
        <div class="inline-block mb-16">
            <h2
                class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-3"
            >
                {tituloSeccion}
            </h2>
            <div class="h-1.5 w-1/3 bg-blue-600 mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
            {
                items.map((item) => (
                    <article class="group relative bg-white p-10 rounded-[2rem] border border-slate-100 transition-all duration-500 hover:-translate-y-3 flex flex-col items-center">
                        <div class="absolute inset-0 bg-gradient-to-b from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-[2rem]" />

                        <div class="relative z-10 flex flex-col items-center w-full">
                            <div class="mb-8 w-20 h-20 flex items-center justify-center bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-50 group-hover:scale-110 group-hover:shadow-blue-100 transition-all duration-500">
                                <Icon
                                    name={item.icon}
                                    class="w-10 h-10 text-slate-800 group-hover:text-blue-600 transition-colors duration-500"
                                />
                            </div>

                            <h3 class="text-xl font-extrabold text-slate-900 mb-4 leading-tight group-hover:text-blue-700 transition-colors">
                                {item.titulo}
                            </h3>

                            <p class="text-slate-500 text-sm leading-relaxed font-medium">
                                {item.descripcion}
                            </p>
                        </div>

                        <div class="absolute inset-0 -z-10 shadow-[0_10px_40px_-15px_rgba(0,0,0,0.05)] group-hover:shadow-[0_20px_50px_-12px_rgba(59,113,202,0.15)] transition-all duration-500 rounded-[2rem]" />
                    </article>
                ))
            }
        </div>
    </div>
</section>
