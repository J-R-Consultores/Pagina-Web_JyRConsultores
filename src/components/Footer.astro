---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import logoImg from "../assets/LOGO_2.png"; 
---

<footer class="bg-linear-to-b from-[#112A40] to-[#537FA6] text-white py-12 px-6 md:px-16 font-sans">
  <div class="border-gray-800/50">

    <div class="group flex justify-center mb-10 cursor-pointer">
      <Image 
        src={logoImg} 
        alt="Logo" 
        class="h-40 w-auto drop-shadow-2xl transition-all duration-500 ease-out transform group-hover:-translate-y-2 group-hover:scale-110 group-hover:brightness-125"
        quality="high"
        format="webp"
      />
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">      
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <Icon name="lucide:map-pin" class="h-5 w-5 text-gray-400" />
          <h3 class="font-bold tracking-widest text-sm">DIRECCIÓN</h3>
        </div>
        <div class="text-xs text-gray-300 leading-relaxed space-y-4">
          <p>Lorem Ipsum 123, Col.<br>Ipsum Lorem, CDMX,<br>01020 México</p>
        </div>
      </div>
  
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <Icon name="lucide:mail" class="h-5 w-5 text-gray-400" />
          <h3 class="font-bold tracking-widest text-sm">EMAIL</h3>
        </div>
        <div class="text-xs text-gray-300 space-y-1">
          <p>contacto@ascg.mx</p>
          <p>contacto@ascg.mx</p>
          <p>contacto@ascg.mx</p>
        </div>
      </div>
  
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <Icon name="lucide:phone" class="h-5 w-5 text-gray-400" />
          <h3 class="font-bold tracking-widest text-sm">TELÉFONOS</h3>
        </div>
        <div class="text-xs text-gray-300 space-y-1">
          <p>+52 55 5859 4873</p>
          <p>+52 55 5840 4611</p>
          <p>+52 55 5859 9296</p>
        </div>
      </div>

      <div class="flex flex-col space-y-4 text-center">
        <div class="flex items-center gap-2">
          <Icon name="lucide:share-2" class="h-5 w-5 text-gray-400" />
          <h3 class="font-bold tracking-widest text-sm">REDES SOCIALES</h3>
        </div>
        <div class="flex items-center gap-6 text-gray-400">
          <a href="https://facebook.com" aria-label="Facebook" target="_blank" class="group flex items-center justify-center w-10 h-10 rounded-full border border-gray-500/30 bg-white/5 transition-all hover:bg-[#537FA6] hover:border-[#537FA6] hover:-translate-y-1">
            <Icon name="lucide:facebook" class="h-5 w-5 group-hover:text-white" />
          </a>
          <a href="https://instagram.com" aria-label="Instagram" target="_blank" class="group flex items-center justify-center w-10 h-10 rounded-full border border-gray-500/30 bg-white/5 transition-all hover:bg-[#537FA6] hover:border-[#537FA6] hover:-translate-y-1">
            <Icon name="lucide:instagram" class="h-5 w-5 group-hover:text-white" />
          </a>
          <a href="https://youtube.com" aria-label="YouTube" target="_blank" class="group flex items-center justify-center w-10 h-10 rounded-full border border-gray-500/30 bg-white/5 transition-all hover:bg-[#537FA6] hover:border-[#537FA6] hover:-translate-y-1">
            <Icon name="lucide:youtube" class="h-5 w-5 group-hover:text-white" />
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto pt-10 flex flex-col items-center gap-6">
      <a href="/aviso-privacidad" class="group relative text-sm font-semibold tracking-widest text-slate-200">
        AVISO DE PRIVACIDAD
        <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-white transition-all duration-300 group-hover:w-full"></span>
      </a>
    </div>

    <div class="pt-4 w-full max-w-xs">
      <span class="text-[11px] font-bold tracking-tighter italic text-white uppercase">
        Desarrollado por AXIS ZC DEVELOPE
      </span>
    </div>
  </div>
</footer>